{
  "info": {
    "name": "OPOSSUM API Collection",
    "description": "API collection for OPOSSUM Lost & Found application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.environment.get('access_token')) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + pm.environment.get('access_token')",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    console.log('Registration successful:', response.message);",
                  "} else {",
                  "    console.log('Registration failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"{{test_username}}\",\n    \"email\": \"{{test_email}}\",\n    \"password\": \"{{test_password}}\",\n    \"firstName\": \"{{test_first_name}}\",\n    \"lastName\": \"{{test_last_name}}\",\n    \"phone\": \"1234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register new user account with email verification"
          }
        },
        {
          "name": "Login as User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('user_access_token', response.accessToken);",
                  "    pm.environment.set('user_refresh_token', response.refreshToken);",
                  "    pm.environment.set('access_token', response.accessToken);",
                  "    pm.environment.set('user_id', response.user.id);",
                  "    pm.environment.set('current_username', response.user.username);",
                  "    pm.environment.set('current_email', response.user.email);",
                  "    console.log('Login successful');",
                  "    console.log('User ID:', response.user.id);",
                  "    console.log('Role:', response.user.role);",
                  "} else {",
                  "    console.log('Login failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"login\": \"{{test_username}}\",\n    \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with username or email and password"
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('admin_access_token', response.accessToken);",
                  "    pm.environment.set('admin_refresh_token', response.refreshToken);",
                  "    pm.environment.set('access_token', response.accessToken);",
                  "    pm.environment.set('admin_id', response.user.id);",
                  "    pm.environment.set('current_username', response.user.username);",
                  "    pm.environment.set('current_email', response.user.email);",
                  "    console.log('Admin login successful');",
                  "    console.log('Admin ID:', response.user.id);",
                  "    console.log('Role:', response.user.role);",
                  "} else {",
                  "    console.log('Admin login failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"login\": \"{{admin_username}}\",\n    \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin user"
          }
        },
        {
          "name": "Switch to User Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const userToken = pm.environment.get('user_access_token');",
                  "if (userToken) {",
                  "    pm.environment.set('access_token', userToken);",
                  "    console.log('Switched to user token');",
                  "} else {",
                  "    console.log('User token not found');",
                  "}"
