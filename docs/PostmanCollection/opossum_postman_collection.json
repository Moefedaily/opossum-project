    },
    {
      "name": "Security Tests",
      "item": [
        {
          "name": "User tries Admin Endpoint",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const userToken = pm.environment.get('user_access_token');",
                  "if (userToken) {",
                  "    pm.environment.set('access_token', userToken);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 403) {",
                  "    console.log('Test passed - User correctly denied admin access');",
                  "} else if (pm.response.code === 200) {",
                  "    console.log('Test failed - User should not access admin endpoints');",
                  "} else {",
                  "    console.log('Unexpected response:', pm.response.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Test user access to admin endpoint"
          }
        },
        {
          "name": "Admin accesses Admin Endpoint",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const adminToken = pm.environment.get('admin_access_token');",
                  "if (adminToken) {",
                  "    pm.environment.set('access_token', adminToken);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('Test passed - Admin correctly has admin access');",
                  "    const users = pm.response.json();",
                  "    console.log('Admin can see', users.length, 'users');",
                  "} else {",
                  "    console.log('Test failed - Admin should access admin endpoints');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Test admin access to admin endpoint"
          }
        },
        {
          "name": "No Token Access",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.request.removeHeader('Authorization');"]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 401) {",
                  "    console.log('Test passed - No token correctly denied access');",
                  "} else {",
                  "    console.log('Test failed - Protected endpoint should require auth');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Test protected endpoint without token"
          }
        }
      ]
    },
