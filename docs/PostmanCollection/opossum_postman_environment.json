{
  "info": {
    "name": "OPOSSUM API Collection",
    "description": "Complete API collection for OPOSSUM Lost & Found application with authentication, user management, email verification, and category system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set Authorization header if access_token exists",
          "if (pm.environment.get('access_token')) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + pm.environment.get('access_token')",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Get Announcement Statistics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/announcements/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "announcements", "stats"]
            },
            "description": "Get announcement counts and statistics for dashboard."
          }
        }
      ]
    },
    {
      "name": "📁 File Upload (Future - Issue #7)",
      "item": [
        {
          "name": "Upload Photo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "announcementId",
                  "value": "{{announcement_id}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/files/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "files", "upload"]
            },
            "description": "Upload photo for announcement (Implementation pending - Issue #7)."
          }
        },
        {
          "name": "Get File",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/files/{{file_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "files", "{{file_id}}"]
            },
            "description": "Get uploaded file by ID (Implementation pending - Issue #7)."
          }
        }
      ]
    },
    {
