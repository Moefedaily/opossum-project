    {
      "name": "🌍 GPS & Location (Future - Issue #6)",
      "item": [
        {
          "name": "Search by Location Radius",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/announcements/nearby?latitude=45.7640&longitude=4.8357&radius=5000",
              "host": ["{{base_url}}"],
              "path": ["api", "announcements", "nearby"],
              "query": [
                {
                  "key": "latitude",
                  "value": "45.7640",
                  "description": "Center latitude"
                },
                {
                  "key": "longitude",
                  "value": "4.8357",
                  "description": "Center longitude"
                },
                {
                  "key": "radius",
                  "value": "5000",
                  "description": "Search radius in meters"
                }
              ]
            },
            "description": "Find announcements within radius of location (Implementation pending - Issue #6)."
          }
        },
        {
          "name": "Calculate Distance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/announcements/{{announcement_id}}/distance?latitude=45.7640&longitude=4.8357",
              "host": ["{{base_url}}"],
              "path": ["api", "announcements", "{{announcement_id}}", "distance"],
              "query": [
                {
                  "key": "latitude",
                  "value": "45.7640",
                  "description": "User latitude"
                },
                {
                  "key": "longitude",
                  "value": "4.8357",
                  "description": "User longitude"
                }
              ]
            },
            "description": "Calculate distance from user to announcement location (Implementation pending - Issue #6)."
          }
        }
      ]
    },
