              "raw": "{\n    \"recipientId\": \"2\",\n    \"announcementId\": \"{{announcement_id}}\",\n    \"content\": \"Hi! I think I found your lost item. Can we meet?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "messages"]
